{% import "drmyts/template/macro/macros.twig" as macros %}

<div class="simplecheckout-block checkout-page__comment checkout-comment" id="simplecheckout_comment"> 
    <button class="btn flex-row checkout-comment__toggler text--upp" type="button"> 
        <div class="icon checkout-comment__icon"> 
            {{ macros.svg('checkout-comment')}}
        </div>
        <span>{% if display_header %}{{ label }}{% else %}Коментар до замовлення{% endif %}</span>
    </button>
    <div class="checkout-comment__body d-none simplecheckout-block-content">
        <div class="checkout-comment_field custom-input custom-input--type_textarea rel custom-input--type_textarea-count"> 
            <textarea class="custom-input__input" name="comment" id="comment" placeholder="{{ placeholder }}" data-reload-payment-form="true" maxlength="500">{{ comment }}</textarea>
            <div class="custom-input__count abs">{{ comment|length}}/500</div>
        </div>
    </div>
</div>