{% macro productCard(thumb, product_id, name, manufacturer, brand_href, price, special, discount, in_wishlist, href, class, model, hide_price, tg_link) %}
    <div class="product-card flex-col {{ class }}">
        <div class="product-card__image-wr bg--white rel w-full">
            <div class="product-card__img rel w-full">
                <picture class="abs inset wh-full">
                    <img class="cover-image" src="{{ thumb }}" alt="{{ name }}" loading="lazy" width="143" height="143" />
                </picture>
            </div>
            <div class="product-card__tools">
                {% if special %}
                    <span class="sale-badge product-card__sale abs text--color_white text--size_sm flex-center">-{{ discount }}%</span>
                {% endif %}
                <button class="btn icon product-card__add-to-wish abs {{ in_wishlist ? 'liked' : '' }}" type="button" onclick="wishlist.toggle(this, '{{ product_id }}');">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 21 19" role="presentation">
                        <path class="product-card__like-icon--empty" d="M11.12 18.21C10.78 18.33 10.22 18.33 9.88 18.21C6.98 17.22 0.5 13.09 0.5 6.09C0.5 3 2.99 0.5 6.06 0.5C7.88 0.5 9.49 1.38 10.5 2.74C11.51 1.38 13.13 0.5 14.94 0.5C18.01 0.5 20.5 3 20.5 6.09C20.5 13.09 14.02 17.22 11.12 18.21Z"  stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
            <a class="product-card__link abs inset wh-full" href="{{ href }}">{{ manufacturer }}</a>
        </div>
        <div class="product-card__content text--center flex-col">
            <a class="product-card__title" href="{{ brand_href }}">{{ manufacturer }}</a>
            <a class="product-card__descr" href="{{ href }}">{% if model %}{{ model }} {% endif %}{{ name }}</a>
            
            <div class="product-price flex-row {{ special ? 'product-price--sale' : '' }} j-center product-card__price">
                {% if hide_price %}
                    <a class="product-card__no-price" href="{{ tg_link }}" target="_blank" rel="noopener noreferrer">Дізнатися вартість</a>
                {% elseif special %}
                    <span class="product-price__full">{{ price }}</span>
                    <span class="product-price__sale">{{ special }}</span>
                {% else %}
                    <span class="product-price__full">{{ price }}</span>
                {% endif %}
            </div>
        </div>
    </div>
{% endmacro %}
